// HRMS Phase 1 - Complete Prisma Schema
// Two Elephants Technologies LLP | v1.0 | April 2026
// Modules: Lookup & Reference | Auth & System | Organisation Masters
//          Employee Core & Profile | Attendance Management

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODULE 1 — LOOKUP & REFERENCE (5 Tables)
// ─────────────────────────────────────────────────────────────────────────────

model LkpCategory {
  id          Int        @id @default(autoincrement())
  code        String     @unique                        // GENDER, BLOOD_GROUP, EMP_TYPE …
  description String
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  values      LkpValue[]

  @@map("lkp_categories")
}

model LkpValue {
  id         Int         @id @default(autoincrement())
  categoryId Int
  code       String                                     // MALE, FEMALE, A_POS …
  label      String                                     // Male, Female, A+ …
  sortOrder  Int         @default(0)
  isActive   Boolean     @default(true)
  metadata   Json?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  category   LkpCategory @relation(fields: [categoryId], references: [id])

  // Employees using this value via various FK fields
  genderEmployees          Employee[]               @relation("EmployeeGender")
  empTypeEmployees         Employee[]               @relation("EmployeeEmpType")
  maritalStatusDetails     EmployeePersonalDetail[] @relation("PersonalMaritalStatus")
  bloodGroupDetails        EmployeePersonalDetail[] @relation("PersonalBloodGroup")
  addressTypeDetails       EmployeeAddressDetail[]  @relation("AddressType")
  identityTypeDetails      EmployeeIdentityDetail[] @relation("IdentityType")
  documentTypeDetails      EmployeeDocument[]       @relation("DocumentType")
  shiftTypeShifts          Shift[]                  @relation("ShiftType")

  @@unique([categoryId, code])
  @@map("lkp_values")
}

model Country {
  id        Int     @id @default(autoincrement())
  isoCode   String  @unique   // IN, US, GB
  name      String
  phoneCode String            // +91, +1
  isActive  Boolean @default(true)

  states    State[]

  @@map("countries")
}

model State {
  id        Int     @id @default(autoincrement())
  countryId Int
  name      String
  code      String            // MH, KA, DL
  isActive  Boolean @default(true)

  country   Country @relation(fields: [countryId], references: [id])
  cities    City[]
  addresses EmployeeAddressDetail[]

  @@unique([countryId, code])
  @@map("states")
}

model City {
  id      Int     @id @default(autoincrement())
  stateId Int
  name    String
  isActive Boolean @default(true)

  state           State            @relation(fields: [stateId], references: [id])
  officeLocations OfficeLocation[]
  addresses       EmployeeAddressDetail[]

  @@map("cities")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODULE 2 — AUTH & SYSTEM (5 Tables)
// ─────────────────────────────────────────────────────────────────────────────

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique   // Must match Keycloak realm role names exactly
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          Int      @id @default(autoincrement())
  code        String   @unique   // employee.view.all, payroll.approve …
  module      String             // ATTENDANCE, PAYROLL, LEAVE, KRA, INSURANCE
  action      String             // view | create | update | delete | approve
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       Int
  permissionId Int
  assignedAt   DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id              String    @id @default(uuid())
  keycloakId      String    @unique   // Keycloak UUID — critical link between both systems
  email           String    @unique
  roleId          Int
  isActive        Boolean   @default(true)
  isEmailVerified Boolean   @default(false)
  lastLoginAt     DateTime?
  deletedAt       DateTime?           // Soft delete — filter WHERE deletedAt IS NULL
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  role         Role          @relation(fields: [roleId], references: [id])
  employee     Employee?
  loginHistory LoginHistory[]

  @@map("users")
}

model LoginHistory {
  id         Int      @id @default(autoincrement())
  userId     String
  eventType  String             // LOGIN | LOGOUT | FAILED | LOCKED | PASSWORD_RESET
  ipAddress  String?
  userAgent  String?
  occurredAt DateTime @default(now())  // Indexed DESC for efficient timeline queries

  user       User     @relation(fields: [userId], references: [id])

  @@index([userId, occurredAt(sort: Desc)])
  @@map("login_history")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODULE 3 — ORGANISATION MASTERS (4 Tables)
// ─────────────────────────────────────────────────────────────────────────────

model Department {
  id               Int     @id @default(autoincrement())
  code             String  @unique   // ENG, HR, FIN, OPS, SALES
  name             String
  parentId         Int?              // NULL for root. Self-ref enables unlimited depth
  headEmployeeId   String?           // FK to Employee — set AFTER employees are created
  costCenter       String?
  isActive         Boolean @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  parent       Department?  @relation("DeptHierarchy", fields: [parentId], references: [id])
  children     Department[] @relation("DeptHierarchy")
  headEmployee Employee?    @relation("DeptHead", fields: [headEmployeeId], references: [id])
  employees    Employee[]   @relation("EmployeeDept")
  designations Designation[]

  @@map("departments")
}

model Designation {
  id           Int     @id @default(autoincrement())
  code         String  @unique   // SDE1, SDE2, SSDE, EM, PM, QA1
  name         String
  departmentId Int
  level        Int               // 1–10 seniority scale — used for pay grade matching
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department Department @relation(fields: [departmentId], references: [id])
  employees  Employee[]

  @@map("designations")
}

model OfficeLocation {
  id        Int      @id @default(autoincrement())
  name      String               // Pune HQ, Bangalore Office, Remote
  latitude  Decimal  @db.Decimal(10, 7)
  longitude Decimal  @db.Decimal(10, 7)
  radiusM   Int      @default(200)  // Geo-fence radius in metres
  cityId    Int
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  city            City             @relation(fields: [cityId], references: [id])
  employees       Employee[]
  attendanceLogs  AttendanceLog[]

  @@map("office_locations")
}

model PayGrade {
  id          Int      @id @default(autoincrement())
  code        String   @unique    // G1, G2 … G10
  description String?             // Junior Engineer, Senior Engineer, Tech Lead
  minCtc      Decimal  @db.Decimal(14, 2)
  maxCtc      Decimal  @db.Decimal(14, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees Employee[]

  @@map("pay_grades")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODULE 4 — EMPLOYEE CORE (Hub of the Schema)
// ─────────────────────────────────────────────────────────────────────────────

model Employee {
  id                   String    @id @default(uuid())
  employeeCode         String    @unique     // EMP-0001, EMP-0002 …
  userId               String    @unique     // One-to-one with User
  firstName            String
  lastName             String
  preferredName        String?
  workEmail            String    @unique
  phonePrimary         String?
  dateOfJoining        DateTime
  dateOfBirth          DateTime?
  probationEndDate     DateTime?
  lastWorkingDate      DateTime?
  reportingManagerId   String?               // Self-ref FK — builds org tree
  departmentId         Int?
  designationId        Int?
  payGradeId           Int?
  officeLocationId     Int?
  genderLkpId          Int?                  // FK to LkpValue (GENDER category)
  employmentTypeLkpId  Int?                  // FK to LkpValue (EMP_TYPE category)
  isActive             Boolean   @default(true)
  deletedAt            DateTime?             // Soft delete
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Auth
  user               User            @relation(fields: [userId], references: [id])

  // Org structure
  department         Department?     @relation("EmployeeDept", fields: [departmentId], references: [id])
  designation        Designation?    @relation(fields: [designationId], references: [id])
  payGrade           PayGrade?       @relation(fields: [payGradeId], references: [id])
  officeLocation     OfficeLocation? @relation(fields: [officeLocationId], references: [id])

  // Self-referential reporting chain
  reportingManager   Employee?  @relation("ReportingChain", fields: [reportingManagerId], references: [id])
  directReports      Employee[] @relation("ReportingChain")

  // Lookup-driven fields
  gender             LkpValue?  @relation("EmployeeGender", fields: [genderLkpId], references: [id])
  employmentType     LkpValue?  @relation("EmployeeEmpType", fields: [employmentTypeLkpId], references: [id])

  // Profile sub-tables
  personalDetail     EmployeePersonalDetail?
  addresses          EmployeeAddressDetail[]
  previousEmployments EmployeePreviousEmployment[]
  educations         EmployeeEducation[]
  identities         EmployeeIdentityDetail[]
  documents          EmployeeDocument[]

  // Attendance
  shifts             EmployeeShift[]
  attendanceLogs     AttendanceLog[]
  attendanceSummaries AttendanceSummary[]

  // Department head ref (inverse)
  headOfDepartments  Department[] @relation("DeptHead")

  @@map("employees")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODULE 5 — EMPLOYEE PROFILE (6 Sub-tables)
// ─────────────────────────────────────────────────────────────────────────────

model EmployeePersonalDetail {
  id                    Int      @id @default(autoincrement())
  employeeId            String   @unique   // One row per employee
  maritalStatusLkpId    Int?
  bloodGroupLkpId       Int?
  emergencyContactName  String?
  emergencyContactPhone String?
  emergencyRelation     String?
  nationality           String?  @default("Indian")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  employee      Employee  @relation(fields: [employeeId], references: [id])
  maritalStatus LkpValue? @relation("PersonalMaritalStatus", fields: [maritalStatusLkpId], references: [id])
  bloodGroup    LkpValue? @relation("PersonalBloodGroup", fields: [bloodGroupLkpId], references: [id])

  @@map("employee_personal_details")
}

model EmployeeAddressDetail {
  id               Int      @id @default(autoincrement())
  employeeId       String
  addressTypeLkpId Int                // FK to LkpValue (ADDRESS_TYPE: Current/Permanent/Temporary)
  line1            String
  line2            String?
  cityId           Int?
  stateId          Int?
  pincode          String?
  countryCode      String   @default("IN")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  employee    Employee  @relation(fields: [employeeId], references: [id])
  addressType LkpValue  @relation("AddressType", fields: [addressTypeLkpId], references: [id])
  city        City?     @relation(fields: [cityId], references: [id])
  state       State?    @relation(fields: [stateId], references: [id])

  @@unique([employeeId, addressTypeLkpId])
  @@map("employee_address_details")
}

model EmployeePreviousEmployment {
  id              Int      @id @default(autoincrement())
  employeeId      String
  companyName     String
  designation     String?
  startDate       DateTime?
  endDate         DateTime?
  reasonForLeaving String?
  isVerified      Boolean  @default(false)   // HR verification flag
  verifiedAt      DateTime?
  verifiedBy      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("employee_previous_employments")
}

model EmployeeEducation {
  id           Int      @id @default(autoincrement())
  employeeId   String
  degree       String             // B.Tech, MBA, PhD …
  institution  String
  fieldOfStudy String?
  startYear    Int?
  endYear      Int?
  grade        String?
  isHighest    Boolean  @default(false)  // Flag for highest qualification
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("employee_educations")
}

model EmployeeIdentityDetail {
  id                 Int      @id @default(autoincrement())
  employeeId         String
  identityTypeLkpId  Int               // FK to LkpValue (IDENTITY_TYPE: PAN/Aadhaar/Passport …)
  identityNumber     String            // ENCRYPTED at application layer before storing
  expiryDate         DateTime?
  isVerified         Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  employee     Employee @relation(fields: [employeeId], references: [id])
  identityType LkpValue @relation("IdentityType", fields: [identityTypeLkpId], references: [id])

  @@unique([employeeId, identityTypeLkpId])
  @@map("employee_identity_details")
}

model EmployeeDocument {
  id              Int      @id @default(autoincrement())
  employeeId      String
  docTypeLkpId    Int               // FK to LkpValue (DOC_TYPE: Offer Letter/Relieving …)
  fileName        String
  fileUrl         String            // Object storage URL (S3 / GCS)
  fileSizeBytes   Int?
  mimeType        String?
  uploadedBy      String?           // Admin userId who uploaded
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
  docType  LkpValue @relation("DocumentType", fields: [docTypeLkpId], references: [id])

  @@map("employee_documents")
}

// ─────────────────────────────────────────────────────────────────────────────
// MODULE 6 — ATTENDANCE MANAGEMENT (4 Tables)
// ─────────────────────────────────────────────────────────────────────────────

model Shift {
  id              Int      @id @default(autoincrement())
  name            String               // Morning Shift, Night Shift, Flexible Work
  shiftTypeLkpId  Int?                 // FK to LkpValue (SHIFT_TYPE)
  startTime       String?              // HH:MM:SS — NULL for flexible shifts
  endTime         String?              // HH:MM:SS
  graceMinutes    Int      @default(15)
  halfDayHours    Decimal  @default(4.5)  @db.Decimal(4, 1)
  fullDayHours    Decimal  @default(9.0)  @db.Decimal(4, 1)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shiftType         LkpValue?         @relation("ShiftType", fields: [shiftTypeLkpId], references: [id])
  employeeShifts    EmployeeShift[]
  attendanceSummaries AttendanceSummary[]

  @@map("shifts")
}

model EmployeeShift {
  id            Int      @id @default(autoincrement())
  employeeId    String
  shiftId       Int
  effectiveFrom DateTime
  effectiveTo   DateTime?   // NULL = currently active shift

  employee Employee @relation(fields: [employeeId], references: [id])
  shift    Shift    @relation(fields: [shiftId], references: [id])

  @@index([employeeId, effectiveTo])
  @@map("employee_shifts")
}

model AttendanceLog {
  id               Int      @id @default(autoincrement())
  employeeId       String
  logDate          DateTime @db.Date
  punchTime        DateTime
  punchType        String             // CHECK_IN | CHECK_OUT | BREAK_IN | BREAK_OUT
  source           String             // WEB | MOBILE | BIOMETRIC | MANUAL
  latitude         Decimal? @db.Decimal(10, 7)
  longitude        Decimal? @db.Decimal(10, 7)
  officeLocationId Int?               // Matched office (if within geo-fence)
  isWithinGeofence Boolean?
  isRegularized    Boolean  @default(false)  // TRUE if HR manually corrected
  regularizedBy    String?
  regularizedAt    DateTime?
  remarks          String?
  ipAddress        String?
  deviceInfo       Json?              // OS, device model, app version
  createdAt        DateTime @default(now())

  employee       Employee        @relation(fields: [employeeId], references: [id])
  officeLocation OfficeLocation? @relation(fields: [officeLocationId], references: [id])

  @@index([employeeId, logDate])
  @@map("attendance_logs")
}

model AttendanceSummary {
  id               Int      @id @default(autoincrement())
  employeeId       String
  attendanceDate   DateTime @db.Date        // One row per employee per day
  shiftId          Int?
  firstCheckIn     DateTime?
  lastCheckOut     DateTime?
  totalHours       Decimal? @db.Decimal(5, 2)
  status           String               // PRESENT | ABSENT | HALF_DAY | ON_LEAVE | WFH | HOLIDAY | WEEKEND
  lateByMinutes    Int?
  overtimeMinutes  Int?
  isLocked         Boolean  @default(false)  // TRUE after payroll run — cannot be edited
  lockedAt         DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
  shift    Shift?   @relation(fields: [shiftId], references: [id])

  @@unique([employeeId, attendanceDate])
  @@index([attendanceDate])
  @@map("attendance_summaries")
}
